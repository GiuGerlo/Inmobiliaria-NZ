APP_NAME="Inmobiliaria NZ"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8080

APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_AR

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Host "mariadb" = servicio del docker compose (no localhost).
DB_CONNECTION=mysql
DB_HOST=mariadb
DB_PORT=3306
DB_DATABASE=inmobiliaria
DB_USERNAME=inmo
DB_PASSWORD=cambiar_en_local

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=localhost

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

CACHE_STORE=file

MAIL_MAILER=log

VITE_APP_NAME="${APP_NAME}"

# Sanctum: dominios SPA permitidos (cookie auth)
SANCTUM_STATEFUL_DOMAINS=localhost:8080,127.0.0.1:8080

# PDF (spatie/laravel-pdf): Gotenberg = Chromium headless en container aparte (ADR-0004).
LARAVEL_PDF_DRIVER=gotenberg
GOTENBERG_URL=http://gotenberg:3000

# WhatsApp Cloud API oficial (Meta) — envío de recibos/rendiciones (sub-I). NUNCA commitear el token.
# Para probar: usar el número de prueba + token temporal (24h) de developers.facebook.com.
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_API_VERSION=v21.0
WHATSAPP_TEMPLATE_RECIBO=
WHATSAPP_TEMPLATE_RENDICION=
WHATSAPP_TEMPLATE_LANG=es
# Envío encolado: en prod (sub-H) usar QUEUE_CONNECTION=database + un worker (queue:work). Local: sync.

# Datos de la inmobiliaria que aparecen en los PDFs (defaults en config/inmobiliaria.php).
NZ_NAME="Nadina Zaranich"
NZ_LOCALITY="Guatimozín"
NZ_ADDRESS="Catamarca 227"
NZ_PHONE="3468-495281"
NZ_HOURS="8 hs a 12 hs - 16 hs a 20 hs"
NZ_CUIT="27-27036340-2"
NZ_COMMISSION_RATE=0.10
