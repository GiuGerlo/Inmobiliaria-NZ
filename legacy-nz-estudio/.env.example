# Copiar este archivo a .env y completar con valores reales.
# .env NO se commitea (ver .gitignore).

# === Entorno Docker (desarrollo local — reemplazo de Laragon) ===
# El servicio web resuelve "db" como hostname dentro de la red interna.
DB_DOCKER_HOST=db
DB_DOCKER_NAME=nz-estudio
DB_DOCKER_USER=nz
DB_DOCKER_PASS=nzdev
DB_DOCKER_ROOT_PASS=rootdev

# === Entorno local legado (Laragon) — DEPRECADO ===
# Mantener por compatibilidad si alguien sigue corriendo el sitio con Laragon.
# Se puede borrar cuando el equipo entero migre a Docker.
DB_LOCAL_HOST=localhost:3307
DB_LOCAL_NAME=nz-estudio
DB_LOCAL_USER=root
DB_LOCAL_PASS=

# === Entorno producción (Hostinger) ===
DB_PROD_HOST=localhost
DB_PROD_NAME=
DB_PROD_USER=
DB_PROD_PASS=

# === Servicios externos ===
# Google Maps API Key (restringir por HTTP referrer al dominio)
GOOGLE_MAPS_API_KEY=

# Google Analytics 4 Measurement ID
GOOGLE_ANALYTICS_ID=
