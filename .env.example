# --------------------------------------------------------------------
# Inmobiliaria NZ — variables de docker compose
# Copiar a .env SOLO si necesitás cambiar algo. Sin .env, los defaults
# del docker-compose.yml funcionan igual. .env NO se commitea.
#
# Las versiones de imágenes (PHP, Node, etc.) NO van acá: están fijadas
# en docker-compose.yml / Dockerfiles por decisión (ver docs/adr/0005).
# --------------------------------------------------------------------

# Puertos host — cambiar solo si chocan con otro servicio local
APP_PORT=8080
PMA_PORT=8081
LEGACY_PORT=8082
DB_PORT=3307

# Credenciales MariaDB locales
DB_DATABASE=inmobiliaria
DB_USERNAME=inmo
DB_PASSWORD=cambiar_en_local
DB_ROOT_PASSWORD=cambiar_root_en_local

# Dump inicial (opcional). Path ABSOLUTO al .sql en tu máquina.
# Vacío = DB arranca vacía. Ejemplo: C:/Users/Tu/privado/db-nz.sql
DB_DUMP_PATH=
